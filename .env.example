# ──────────────────────────────────────────────────────────────────────────
# Belleza Ser — variables de entorno
# Copiá este archivo a `.env` y completá los valores. `docker-compose` lo lee.
# ──────────────────────────────────────────────────────────────────────────

# ── Base de datos (Postgres) ───────────────────────────────────────────────
POSTGRES_USER=belleza
POSTGRES_PASSWORD=belleza_dev_password
POSTGRES_DB=belleza_ser
# Puerto expuesto en el host (dentro de la red de docker siempre es 5432)
POSTGRES_PORT=5432

# ── Backend (FastAPI) ───────────────────────────────────────────────────────
# Cadena de conexión async. En docker el host es el nombre del servicio: `db`.
# Para correr la API nativa (fuera de docker) usá: ...@localhost:5432/...
DATABASE_URL=postgresql+asyncpg://belleza:belleza_dev_password@db:5432/belleza_ser
# Orígenes permitidos por CORS (coma-separados). El front en dev corre en :3000.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Proveedor de pagos. v1 = stub (no cobra). v2 = mercadopago.
PAYMENT_PROVIDER=stub
# (Futuro) Credenciales de Mercado Pago — dejar vacías en v1.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ── Frontend (Nuxt) ──────────────────────────────────────────────────────────
# URL pública del sitio (para canonical / Open Graph).
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Base de la API. En docker el front llama al servicio `api`; desde el navegador
# del usuario se resuelve por la URL pública del backend.
NUXT_PUBLIC_API_BASE=http://localhost:8000
# Número de WhatsApp en formato internacional SIN '+' ni espacios (ej AR: 54911...).
NUXT_PUBLIC_WHATSAPP_NUMBER=5491100000000
# Usuario de Instagram (sin @).
NUXT_PUBLIC_INSTAGRAM_USER=enbellezaser
